# ARDEN Production Environment Configuration
# rocket.id10t.social - Hetzner VPS Deployment
# CPU-optimized setup using OpenAI APIs

# ============================================================================
# REQUIRED: Telegram Bot Token
# ============================================================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ============================================================================
# AI PROVIDER - OpenAI (Cloud-based for CPU-only VPS)
# ============================================================================
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# VOICE CONFIGURATION - OpenAI Whisper API + Edge TTS
# ============================================================================
# Using OpenAI Whisper API for STT (cloud-based, no local processing)
# Using Edge TTS for voice output (free Microsoft TTS)
WHISPER_API_KEY=your-openai-api-key-here
# Note: Same key as OPENAI_API_KEY

# ============================================================================
# WEB SERVER CONFIGURATION
# ============================================================================
WEB_PORT=3001
WEB_HOST=127.0.0.1
SESSION_SECRET=generate-random-secret-here

# ============================================================================
# TELEGRAM BOT CONFIGURATION
# ============================================================================
BOT_PORT=3000
BOT_HOST=127.0.0.1

# ============================================================================
# SECURITY
# ============================================================================
ARDEN_API_TOKEN=generate-random-token-here
NODE_ENV=production

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_DIR=/var/log/arden

# ============================================================================
# SETUP NOTES FOR ROCKET.ID10T.SOCIAL
# ============================================================================
# This configuration uses:
# - OpenAI GPT-4o-mini for AI responses (~$0.15 per 1M tokens)
# - OpenAI Whisper API for speech-to-text (~$0.006 per minute)
# - Edge TTS for text-to-speech (FREE)
# 
# Estimated monthly cost: $3-5/month
# Performance: ~3-6 second response time
# 
# To generate secrets:
# SESSION_SECRET: openssl rand -hex 32
# ARDEN_API_TOKEN: openssl rand -hex 32
