# Docker ignore file for ARDEN
# Prevents unnecessary files from being copied into the Docker image

# Node modules (will be installed in container)
node_modules/
api/node_modules/

# Python virtual environment (will be created in container)
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Environment files (use docker-compose env or secrets)
.env
.env.local
.env.*.local

# Git
.git/
.gitignore
.gitattributes

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs (will be generated in volumes)
*.log
api/logs/*.log
logs/

# Test files and coverage
api/__tests__/
api/coverage/
*.test.js
coverage/
.nyc_output/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Documentation (not needed in runtime)
*.md
docs/
README.md

# Build artifacts
dist/
build/
*.tgz

# Temporary files
tmp/
temp/
*.tmp

# OS files
Thumbs.db
.DS_Store

# Docker files (already in context)
Dockerfile*
docker-compose*.yml
.dockerignore

# History and recordings (will be mounted as volumes)
history/
voice/recordings/
voice/responses/

# Models (will be downloaded or mounted)
models/
*.onnx
*.bin
*.pt
*.pth
