# Production Environment Configuration for ARDEN
# Copy this to .env and fill in your values

# ============================================
# REQUIRED: Telegram Bot Configuration
# ============================================
#TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_TOKEN=8539230249:AAEUz83RgvKjIoRduHzbI7zPSbZ_UVxhqyc

# ============================================
# AI Provider Selection
# ============================================
# Options: claude, ollama, openai, lmstudio
AI_PROVIDER=ollama

# ============================================
# OpenAI Configuration
# ============================================
# Required if:
# - AI_PROVIDER=openai
# - Using OpenAI Whisper STT (config/arden.json: stt_provider=openai-whisper)
# - Using OpenAI TTS (config/arden.json: tts_provider=openai-tts)
OPENAI_API_KEY=

# OpenAI model (only if AI_PROVIDER=openai)
OPENAI_MODEL=gpt-4o-mini

# ============================================
# ElevenLabs TTS (Optional)
# ============================================
# Required only if using ElevenLabs TTS
# (config/arden.json: tts_provider=elevenlabs)
ELEVENLABS_API_KEY=

# ============================================
# Ollama Configuration (Optional)
# ============================================
# Only needed if AI_PROVIDER=ollama
# Use 'http://ollama:11434' when using docker-compose with ollama service
# Use 'http://localhost:11434' when running Ollama on host
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ============================================
# LM Studio Configuration (Optional)
# ============================================
# Only needed if AI_PROVIDER=lmstudio
# Use 'http://host.docker.internal:1234' to access LM Studio on host machine
LMSTUDIO_URL=http://host.docker.internal:1234

# ============================================
# Logging Configuration
# ============================================
# Options: error, warn, info, debug
LOG_LEVEL=info

# ============================================
# Node Environment
# ============================================
NODE_ENV=production
