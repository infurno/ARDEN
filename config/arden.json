{
  "version": "1.0.0",
  "name": "ARDEN",
  "description": "AI Routine Daily Engagement Nexus",
  "voice": {
    "enabled": true,
    "stt_provider": "local-whisper",
    "stt_config": {
      "model": "base",
      "language": "en",
      "device": "cuda"
    },
    "tts_provider": "edge-tts",
    "tts_config": {
      "voice": "en-US-AndrewNeural"
    },
    "wake_word": "Hey ARDEN",
    "notifications": true,
    "debug_mode": false
  },
  "api": {
    "enabled": true,
    "port": 3000,
    "host": "0.0.0.0",
    "auth_token_env": "ARDEN_API_TOKEN",
    "cors_enabled": true,
    "rate_limit": {
      "window_ms": 900000,
      "max_requests": 100
    }
  },
  "telegram": {
    "enabled": false,
    "bot_token_env": "TELEGRAM_BOT_TOKEN",
    "allowed_users": []
  },
  "discord": {
    "enabled": false,
    "bot_token_env": "DISCORD_BOT_TOKEN",
    "allowed_users": []
  },
  "context": {
    "directories": [
      "~/ARDEN/context",
      "~/Notes",
      "~/Documents",
      "~/Projects"
    ],
    "auto_load_skills": true,
    "history_enabled": true
  },
  "agents": {
    "default": "assistant",
    "available": [
      "strategist",
      "researcher",
      "engineer",
      "analyst",
      "assistant"
    ]
  },
  "hooks": {
    "session_start": true,
    "post_tool_use": true,
    "stop": true,
    "pre_tool_use": true
  },
  "security": {
    "audit_logging": true,
    "command_validation": true,
    "allowed_tools": [
      "*"
    ],
    "blocked_commands": [
      "rm -rf /",
      "dd if=",
      ":(){ :|:& };:"
    ]
  },
  "clawdbot_partnership": {
    "enabled": true,
    "api_url": "http://127.0.0.1:18789/api",
    "api_key": "your-clawdbot-api-key",
    "timeout": 30000,
    "retry_attempts": 3,
    "webhook_secret": "your-clawdbot-webhook-secret",
    "supported_platforms": ["whatsapp", "telegram"],
    "automation_enabled": true,
    "collaboration_mode": "bidirectional"
  },
  "routines": {
    "morning_briefing": {
      "enabled": true,
      "time": "08:00",
      "agent": "assistant"
    },
    "evening_review": {
      "enabled": true,
      "time": "18:00",
      "agent": "analyst"
    }
  },
  "memory": {
    "enabled": true,
    "backend": "python",
    "server_url": "http://127.0.0.1:3002",
    "embedding_model": "fastembed",
    "embedding_dimensions": 384,
    "search_weights": {
      "vector": 0.7,
      "bm25": 0.3
    },
    "auto_ingest": true,
    "ingest_paths": [
      "~/Notes",
      "daily/",
      "skills/"
    ]
  },
  "heartbeat": {
    "enabled": true,
    "interval_minutes": 30,
    "sources": {
      "gmail": {
        "enabled": true,
        "credentials_env": "GMAIL_CREDENTIALS_PATH"
      },
      "calendar": {
        "enabled": true,
        "credentials_env": "GMAIL_CREDENTIALS_PATH"
      }
    },
    "reasoning": {
      "provider": "anthropic",
      "model": "claude-3-5-sonnet-20241022"
    },
    "notification_endpoint": "http://127.0.0.1:3001/api/notify"
  },
  "slack": {
    "enabled": false,
    "bot_token_env": "SLACK_BOT_TOKEN",
    "app_token_env": "SLACK_APP_TOKEN",
    "socket_mode": true,
    "allowed_users": []
  }
}