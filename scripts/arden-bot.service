[Unit]
Description=ARDEN Telegram Bot
After=network.target ollama.service

[Service]
Type=simple
User=arden
WorkingDirectory=/home/arden/ARDEN
Environment="NODE_ENV=production"
Environment="PATH=/home/arden/ARDEN/venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/usr/bin/node /home/arden/ARDEN/api/telegram-bot.js
Restart=always
RestartSec=10
StandardOutput=append:/home/arden/ARDEN/logs/arden-bot.log
StandardError=append:/home/arden/ARDEN/logs/arden-bot-error.log

# Security settings
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/arden/ARDEN/logs /home/arden/ARDEN/history /home/arden/ARDEN/voice

[Install]
WantedBy=multi-user.target
