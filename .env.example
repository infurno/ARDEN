# ARDEN Environment Configuration Template
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env to version control!

# ============================================================================
# REQUIRED: Telegram Bot Token
# ============================================================================
# Create a bot with @BotFather on Telegram
# 1. Message @BotFather
# 2. Send /newbot
# 3. Follow prompts
# 4. Copy token here
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ============================================================================
# AI PROVIDER CONFIGURATION
# ============================================================================
# Choose your AI provider: ollama, openai, lmstudio, claude
AI_PROVIDER=openai

# Option 1: Ollama (LOCAL - FREE & UNLIMITED - REQUIRES GPU FOR GOOD PERFORMANCE!)
# Install: brew install ollama (macOS) or curl -fsSL https://ollama.com/install.sh | sh (Linux)
# Start: ollama serve
# Pull model: ollama pull llama3.2
# OLLAMA_MODEL=llama3.2
# OLLAMA_URL=http://localhost:11434
# NOTE: CPU-only Ollama is VERY SLOW (10-30s per response). Not recommended for VPS without GPU.

# Option 2: OpenAI (CLOUD - CHEAP & FAST - RECOMMENDED FOR CPU-ONLY VPS)
# Get your key at: https://platform.openai.com/api-keys
# Cost: ~$0.15 per 1M tokens (very cheap, ~$1-2/month typical usage)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Option 3: LM Studio (LOCAL - FREE with GUI)
# Install: brew install --cask lm-studio
# Start server in LM Studio app
# LMSTUDIO_URL=http://localhost:1234

# Option 4: Claude Code (if using Claude directly)
# Uses CLI, no API key needed if you have Claude Code installed
# AI_PROVIDER=claude

# ============================================================================
# VOICE CONFIGURATION
# ============================================================================
# Speech-to-text and text-to-speech are configured in config/arden.json
# Default setup uses FREE options:
# - STT: local-whisper (runs on your hardware)
# - TTS: edge-tts (Microsoft's free cloud TTS)

# OPTIONAL: OpenAI API Key for faster cloud-based Whisper STT
# RECOMMENDED FOR CPU-ONLY VPS: Use OpenAI Whisper API instead of local
# Cost: ~$0.006 per minute of audio (~$1-2/month typical usage)
# If not set, local Whisper will be used (5-15s on CPU vs 1-2s on API)
OPENAI_API_KEY=sk-your-openai-api-key-here
USE_OPENAI_WHISPER=true

# OPTIONAL: ElevenLabs API (for premium voice quality)
# If not set, Edge TTS will be used (free and good quality)
# Get your key at: https://elevenlabs.io
# ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ============================================================================
# SECURITY: ARDEN API Token
# ============================================================================
# Generate a random secure token for API authentication
# Generate with: openssl rand -hex 32
ARDEN_API_TOKEN=your-random-secure-token-here

# ============================================================================
# OPTIONAL: Anthropic API (if using API mode instead of CLI)
# ============================================================================
# Get your key at: https://console.anthropic.com/
# Only needed if you want to use API mode instead of Claude Code CLI
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ============================================================================
# OPTIONAL: Alternative Voice Providers
# ============================================================================

# Deepgram (alternative STT - faster, similar quality to Whisper)
# DEEPGRAM_API_KEY=your-deepgram-api-key-here

# Google Cloud (for STT/TTS)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Azure Speech Services
# AZURE_SPEECH_KEY=your-azure-key-here
# AZURE_SPEECH_REGION=your-region

# ============================================================================
# SETUP EXAMPLES
# ============================================================================

# 100% FREE SETUP (Requires GPU for acceptable performance):
# TELEGRAM_BOT_TOKEN=your-token
# AI_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2
# (Uses: Ollama + Local Whisper + Edge TTS)
# Cost: $0/month
# Performance: FAST with GPU (1-4s), SLOW on CPU (15-40s)

# CPU-ONLY VPS SETUP (Recommended for rocket.id10t.social):
# TELEGRAM_BOT_TOKEN=your-token
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-4o-mini
# USE_OPENAI_WHISPER=true
# (Uses: OpenAI GPT-4o-mini + OpenAI Whisper API + Edge TTS)
# Cost: ~$2-4/month
# Performance: FAST (3-6s total response time)

# BUDGET CPU-ONLY SETUP (Slower transcription):
# TELEGRAM_BOT_TOKEN=your-token
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-4o-mini
# (Uses: OpenAI GPT-4o-mini + Local Whisper + Edge TTS)
# Cost: ~$1-2/month
# Performance: Medium (7-19s, slow transcription but fast AI)

# PREMIUM SETUP:
# TELEGRAM_BOT_TOKEN=your-token
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-4o-mini
# ELEVENLABS_API_KEY=your-key
# USE_OPENAI_WHISPER=true
# (Uses: OpenAI + Cloud Whisper + ElevenLabs)
# Cost: ~$15-20/month
# Performance: FAST with premium voices

# ============================================================================
# SECURITY NOTES
# ============================================================================
# - Keep this file secure
# - Never commit to git (.env is in .gitignore)
# - Rotate keys periodically
# - Use least-privilege API keys
# - Restrict Telegram bot to authorized users (config/arden.json)
